{
  "name": "numpy-ts",
  "version": "1.4.0",
  "description": "Fast, Complete NumPy for TypeScript & JavaScript",
  "main": "dist/esm/index.js",
  "browser": "dist/numpy-ts.browser.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/numpy-ts.browser.js",
    "dist/esm/**/*.js",
    "dist/types/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/numpy-ts.browser.js",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./node": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./core": {
      "types": "./dist/types/core.d.ts",
      "import": "./dist/esm/core.js",
      "default": "./dist/esm/core.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:clean && pnpm run generate && pnpm run build:wasm && tsx build.ts && pnpm run build:types",
    "build:clean": "rm -rf dist",
    "build:types": "tsc --emitDeclarationOnly --rootDir src --outDir dist/types",
    "build:wasm": "tsx scripts/build-wasm.ts",
    "build:wasm:safe": "tsx scripts/build-wasm.ts --safe",
    "build:wasm:small": "tsx scripts/build-wasm.ts --small",
    "build:test": "pnpm run build:clean && pnpm run generate && pnpm run build:wasm:safe && tsx build.ts --skip-wasm && pnpm run build:types",
    "generate": "tsx scripts/generate-full.ts && biome format --write src/full/index.ts src/full/ndarray.ts",
    "test": "pnpm run build:test && vitest run --project=unit --project=validation --project=runtime-io --project=bundle-esm --project=wasm-memory --project=tree-shaking --project=leaks",
    "test:unit": "vitest run --project=unit",
    "test:validation": "vitest run --project=validation",
    "test:io": "vitest run --project=runtime-io",
    "test:wasm-memory": "vitest run --project=wasm-memory",
    "test:leaks": "vitest run --project=leaks",
    "test:leaks:large": "LEAK_SIZE_SCALE=large vitest run --project=leaks",
    "test:dtypes": "vitest run --project=validation tests/validation/dtype-sweep/",
    "test:dtypes:js": "FORCE_BACKEND=js vitest run --project=validation tests/validation/dtype-sweep/",
    "test:dtypes:wasm": "FORCE_BACKEND=wasm vitest run --project=validation tests/validation/dtype-sweep/",
    "test:tree-shaking": "vitest run --project=tree-shaking",
    "test:browser": "pnpm run build:clean && pnpm run generate && tsx build.ts --skip-wasm && pnpm run build:types && vitest run --project=browser-unit --project=bundle-browser --project=bundle-esm",
    "test:bun": "pnpm run build:test && bun vitest run --project=unit --project=validation --project=runtime-io",
    "test:deno": "pnpm run build:test && deno run -A node_modules/.bin/vitest run --project=unit --project=validation --project=runtime-io",
    "test:coverage": "vitest run --project=unit --project=validation --project=runtime-io --project=wasm-memory --coverage",
    "test:ci": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "lint": "biome check src tests scripts benchmarks/src && zig fmt --check src/common/wasm/zig",
    "lint:fix": "biome check --write src tests scripts benchmarks/src && zig fmt src/common/wasm/zig",
    "format": "biome format --write src tests scripts benchmarks/src && zig fmt src/common/wasm/zig",
    "typecheck": "tsc --noEmit",
    "report:api-coverage": "python3 scripts/compare-api-coverage.py",
    "report:docs-api-coverage": "python3 scripts/compare-docs-api-coverage.py",
    "report:dtype-coverage": "npx tsx scripts/dtype-coverage-report.ts",
    "report:zig-coverage": "npx tsx scripts/zig-fn-coverage.ts",
    "report:zig-dead-code": "npx tsx scripts/zig-dead-code.ts",
    "report:slowest": "tsx scripts/slowest-functions.ts",
    "report:wasm-size": "tsx scripts/wasm-size.ts",
    "bench:build": "esbuild benchmarks/src/index.ts --bundle --platform=node --format=cjs --external:pyodide --outfile=benchmarks/dist/bench.cjs && esbuild benchmarks/src/runtime-runner.ts --bundle --platform=neutral --format=esm --external:node:fs --external:node:fs/promises --outfile=benchmarks/dist/runtime-runner.mjs",
    "bench": "pnpm run bench:build && node benchmarks/dist/bench.cjs --full",
    "bench:node": "pnpm run bench:build && node benchmarks/dist/bench.cjs --full --runtime node",
    "bench:pyodide": "pnpm run bench:build && node benchmarks/dist/bench.cjs --full --pyodide --runtime node",
    "bench:all": "pnpm run bench:node && pnpm run bench:node -- --size small && pnpm run bench:node -- --size large && pnpm run bench:pyodide && pnpm run bench",
    "bench:deno": "pnpm run bench:build && node benchmarks/dist/bench.cjs --full --runtime deno",
    "bench:bun": "pnpm run bench:build && node benchmarks/dist/bench.cjs --full --runtime bun",
    "bench:compare": "tsx benchmarks/scripts/compare.ts",
    "bench:regenerate": "tsx benchmarks/scripts/regenerate-charts.ts",
    "bench:js-libs:install": "pnpm -C benchmarks/js-libs install",
    "bench:js-libs:probe": "pnpm run bench:js-libs:install && pnpm -C benchmarks/js-libs run probe",
    "bench:js-libs": "pnpm run bench:js-libs:install && tsx benchmarks/js-libs/run.ts",
    "bench:js-libs:f32": "pnpm run bench:js-libs:install && tsx benchmarks/js-libs/run.ts --dtype float32",
    "bench:view": "open benchmarks/results/plots/latest-full.html || xdg-open benchmarks/results/plots/latest-full.html",
    "bench:docs": "python3 scripts/generate-bench-docs.py && python3 scripts/generate-overview-charts.py"
  },
  "keywords": [
    "numpy",
    "array",
    "ndarray",
    "matrix",
    "linear-algebra",
    "scientific-computing",
    "math",
    "statistics",
    "fft",
    "typescript",
    "javascript"
  ],
  "author": "Nicolas Dupont",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dupontcyborg/numpy-ts.git"
  },
  "bugs": {
    "url": "https://github.com/dupontcyborg/numpy-ts/issues"
  },
  "homepage": "https://numpyts.dev",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.0",
    "pyodide": "^314.0.0",
    "rollup": "^4.62.0",
    "ts-loader": "^9.6.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write"
    ]
  }
}
