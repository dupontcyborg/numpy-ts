{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "esnext.float16", "esnext.disposable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
